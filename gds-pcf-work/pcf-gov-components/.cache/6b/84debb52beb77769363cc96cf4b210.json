next,\r\n.govuk-pagination__prev {\r\n  font-weight: 700;\r\n}\r\n\r\n.govuk-pagination__item--prev,\r\n.govuk-pagination__item--next {\r\n  display: block;\r\n}\r\n\r\n.govuk-pagination__item--prev .govuk-pagination__link,\r\n.govuk-pagination__item--next .govuk-pagination__link,\r\n.govuk-pagination__next .govuk-pagination__link,\r\n.govuk-pagination__prev .govuk-pagination__link {\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n}\r\n\r\n.govuk-pagination__item--prev,\r\n.govuk-pagination__prev {\r\n  padding-left: 0;\r\n}\r\n\r\n.govuk-pagination__item--next,\r\n.govuk-pagination__next {\r\n  padding-right: 0;\r\n}\r\n\r\n.govuk-pagination__item--current,\r\n.govuk-pagination__item--ellipsis,\r\n.govuk-pagination__item:first-child,\r\n.govuk-pagination__item:last-child {\r\n  display: block;\r\n}\r\n\r\n.govuk-pagination__item--current {\r\n  font-weight: 700;\r\n  outline: 1px solid transparent;\r\n  background-color: #1a65a6;\r\n}\r\n\r\n.govuk-pagination__item--current:hover {\r\n  background-color: #1a65a6;\r\n}\r\n\r\n.govuk-pagination__item--current .govuk-pagination__link {\r\n  color: #ffffff;\r\n  text-decoration: none;\r\n}\r\n\r\n.govuk-pagination__item--current .govuk-pagination__link:focus {\r\n  color: #0b0c0c;\r\n}\r\n\r\n.govuk-pagination__item--ellipsis {\r\n  font-weight: 700;\r\n  color: #484949;\r\n  text-decoration: none;\r\n}\r\n\r\n.govuk-pagination__item--ellipsis:hover {\r\n  background-color: transparent;\r\n}\r\n\r\n.govuk-pagination__link {\r\n  display: block;\r\n  min-width: 15px;\r\n  min-height: 100%;\r\n  color: #1a65a6;\r\n  background: none;\r\n  border: 0;\r\n  text-decoration: underline;\r\n  text-decoration-thickness: max(1px, 0.0625rem);\r\n  text-underline-offset: 0.1578em;\r\n  cursor: pointer;\r\n  font-family: inherit;\r\n  font-size: inherit;\r\n  line-height: inherit;\r\n  padding: 0;\r\n  width: 100%;\r\n}\r\n\r\n.govuk-pagination__link:hover {\r\n  color: #0f385c;\r\n  text-decoration-thickness: max(3px, 0.1875rem, 0.12em);\r\n  text-decoration-skip-ink: none;\r\n}\r\n\r\n/* Current page link hover must come after general hover to override */\r\n.govuk-pagination__item--current .govuk-pagination__link:hover {\r\n  color: #ffffff;\r\n  text-decoration: none;\r\n}\r\n\r\n@media screen {\r\n  .govuk-pagination__link::after {\r\n    content: \"\";\r\n    position: absolute;\r\n    top: 0;\r\n    right: 0;\r\n    bottom: 0;\r\n    left: 0;\r\n  }\r\n}\r\n\r\n.govuk-pagination__link:focus {\r\n  outline: 3px solid transparent;\r\n  color: #0b0c0c;\r\n  background-color: #fd0;\r\n  box-shadow: 0 -2px #fd0, 0 4px #0b0c0c;\r\n  text-decoration: none;\r\n  z-index: 1;\r\n}\r\n\r\n.govuk-pagination__link:active {\r\n  color: #0b0c0c;\r\n}\r\n\r\n.govuk-pagination__link:focus .govuk-pagination__icon {\r\n  color: #0b0c0c;\r\n}\r\n\r\n.govuk-pagination__link[disabled] {\r\n  color: #484949;\r\n  cursor: not-allowed;\r\n  text-decoration: none;\r\n}\r\n\r\n.govuk-pagination__item--prev .govuk-pagination__link[disabled],\r\n.govuk-pagination__item--next .govuk-pagination__link[disabled] {\r\n  color: #b1b4b6;\r\n  text-decoration: none;\r\n}\r\n\r\n.govuk-pagination__link[disabled]:hover {\r\n  background-color: transparent;\r\n}\r\n\r\n.govuk-pagination__item--current .govuk-pagination__link {\r\n  cursor: default;\r\n}\r\n\r\n.govuk-pagination__item--prev,\r\n.govuk-pagination__prev {\r\n  padding-left: 0;\r\n}\r\n\r\n.govuk-pagination__item--next,\r\n.govuk-pagination__next {\r\n  padding-right: 0;\r\n}\r\n\r\n/* Support for link-based structure */\r\n.govuk-pagination__link-title {\r\n  display: inline-block;\r\n}\r\n\r\n.govuk-pagination__link-label {\r\n  font-weight: 400;\r\n  display: inline-block;\r\n}\r\n\r\n.govuk-pagination__icon {\r\n  width: 0.9375rem;\r\n  height: 0.8125rem;\r\n  color: #484949;\r\n  fill: currentcolor;\r\n  forced-color-adjust: auto;\r\n}\r\n\r\n.govuk-pagination__icon--prev {\r\n  margin-right: 15px;\r\n}\r\n\r\n.govuk-pagination__icon--next {\r\n  margin-left: 15px;\r\n}\r\n\r\n/* Visually hidden utility - hides content visually but keeps it available to screen readers */\r\n.govuk-visually-hidden {\r\n  position: absolute !important;\r\n  width: 1px !important;\r\n  height: 1px !important;\r\n  margin: 0 !important;\r\n  padding: 0 !important;\r\n  overflow: hidden !important;\r\n  clip: rect(0 0 0 0) !important;\r\n  clip-path: inset(50%) !important;\r\n  border: 0 !important;\r\n  white-space: nowrap !important;\r\n  -webkit-user-select: none;\r\n  -ms-user-select: none;\r\n  user-select: none;\r\n}\r\n\r\n.govuk-visually-hidden::before,\r\n.govuk-visually-hidden::after {\r\n  content: \" \";\r\n}\r\n"},"lineCount":null}},"error":null,"hash":"c7f7b2107d19988458b08d100d911f0f","cacheData":{"env":{}}}