components/Tabs/Tabs.css","original":{"line":233,"column":0},"generated":{"line":233,"column":0}},{"source":"../src/components/Tabs/Tabs.css","original":{"line":234,"column":0},"generated":{"line":234,"column":0}},{"source":"../src/components/Tabs/Tabs.css","original":{"line":235,"column":0},"generated":{"line":235,"column":0}},{"source":"../src/components/Tabs/Tabs.css","original":{"line":236,"column":0},"generated":{"line":236,"column":0}},{"source":"../src/components/Tabs/Tabs.css","original":{"line":237,"column":0},"generated":{"line":237,"column":0}},{"source":"../src/components/Tabs/Tabs.css","original":{"line":238,"column":0},"generated":{"line":238,"column":0}},{"source":"../src/components/Tabs/Tabs.css","original":{"line":239,"column":0},"generated":{"line":239,"column":0}},{"source":"../src/components/Tabs/Tabs.css","original":{"line":240,"column":0},"generated":{"line":240,"column":0}},{"source":"../src/components/Tabs/Tabs.css","original":{"line":241,"column":0},"generated":{"line":241,"column":0}},{"source":"../src/components/Tabs/Tabs.css","original":{"line":242,"column":0},"generated":{"line":242,"column":0}},{"source":"../src/components/Tabs/Tabs.css","original":{"line":243,"column":0},"generated":{"line":243,"column":0}},{"source":"../src/components/Tabs/Tabs.css","original":{"line":244,"column":0},"generated":{"line":244,"column":0}},{"source":"../src/components/Tabs/Tabs.css","original":{"line":245,"column":0},"generated":{"line":245,"column":0}}],"sources":{"../src/components/Tabs/Tabs.css":"/* Tabs component styles - Based on GOV.UK Frontend v6.1.0 */\r\n\r\n/* ── Base ── */\r\n\r\n.govuk-tabs {\r\n  font-family: -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, Oxygen-Sans, Ubuntu, Cantarell, \"Helvetica Neue\", sans-serif;\r\n  -webkit-font-smoothing: antialiased;\r\n  -moz-osx-font-smoothing: grayscale;\r\n\r\n  /* govuk-font($size: 19) — mobile */\r\n  font-size: 1rem;\r\n  line-height: 1.25;\r\n  font-weight: 400;\r\n\r\n  /* govuk-responsive-margin(1, \"top\") = 5px */\r\n  margin-top: 5px;\r\n  /* govuk-responsive-margin(6, \"bottom\") — mobile: 20px */\r\n  margin-bottom: 20px;\r\n}\r\n\r\n@media (min-width: 40.0625em) {\r\n  .govuk-tabs {\r\n    font-size: 1.1875rem;\r\n    line-height: 1.31579;\r\n  }\r\n}\r\n\r\n@media (min-width: 40.0625em) {\r\n  .govuk-tabs {\r\n    margin-bottom: 30px;\r\n  }\r\n}\r\n\r\n@media print {\r\n  .govuk-tabs {\r\n    font-family: sans-serif;\r\n    font-size: 14pt;\r\n    line-height: 1.15;\r\n  }\r\n}\r\n\r\n/* ── Title (visible on mobile, hidden on tablet with JS) ── */\r\n\r\n.govuk-tabs__title {\r\n  font-size: 1rem;\r\n  line-height: 1.25;\r\n  font-weight: 400; /* govuk-typography-weight-regular */\r\n  margin-bottom: 10px; /* govuk-spacing(2) */\r\n  color: #0b0c0c;\r\n}\r\n\r\n@media (min-width: 40.0625em) {\r\n  .govuk-tabs__title {\r\n    font-size: 1.1875rem;\r\n    line-height: 1.31579;\r\n  }\r\n}\r\n\r\n/* ── Tab list ── */\r\n\r\n.govuk-tabs__list {\r\n  margin: 0;\r\n  padding: 0;\r\n  list-style: none;\r\n  /* govuk-responsive-margin(6, \"bottom\") — mobile: 20px */\r\n  margin-bottom: 20px;\r\n}\r\n\r\n@media (min-width: 40.0625em) {\r\n  .govuk-tabs__list {\r\n    margin-bottom: 30px;\r\n  }\r\n}\r\n\r\n/* ── Tab list items (mobile: stacked with em-dash) ── */\r\n\r\n.govuk-tabs__list-item {\r\n  margin-left: 25px; /* govuk-spacing(5) */\r\n}\r\n\r\n.govuk-tabs__list-item::before {\r\n  content: \"\\2014 \"; /* em dash */\r\n  margin-left: -25px; /* -govuk-spacing(5) */\r\n  padding-right: 5px; /* govuk-spacing(1) */\r\n  color: #0b0c0c;\r\n}\r\n\r\n/* ── Tab link (mobile) ── */\r\n\r\n.govuk-tabs__tab {\r\n  /* govuk-link-common */\r\n  text-decoration: underline;\r\n  text-decoration-thickness: max(1px, 0.0625rem);\r\n  text-underline-offset: 0.1578em;\r\n\r\n  /* govuk-link-style-default: link = blue shade-10 */\r\n  color: #1a65a6;\r\n\r\n  display: inline-block;\r\n  margin-bottom: 10px; /* govuk-spacing(2) */\r\n}\r\n\r\n.govuk-tabs__tab:visited {\r\n  color: #54319f; /* govuk-colour(\"purple\") — v6.1.0 */\r\n}\r\n\r\n.govuk-tabs__tab:hover {\r\n  color: #0f385c; /* govuk-functional-colour(link-hover) = blue shade-50 */\r\n  text-decoration-thickness: max(3px, 0.1875rem, 0.12em);\r\n  -webkit-text-decoration-skip-ink: none;\r\n  text-decoration-skip-ink: none;\r\n  -webkit-text-decoration-skip: none;\r\n  text-decoration-skip: none;\r\n}\r\n\r\n.govuk-tabs__tab:active {\r\n  color: #0b0c0c;\r\n}\r\n\r\n.govuk-tabs__tab:focus {\r\n  outline: 3px solid transparent;\r\n  color: #0b0c0c;\r\n  background-color: #ffdd00;\r\n  box-shadow: 0 -2px #ffdd00, 0 4px #0b0c0c;\r\n  text-decoration: none;\r\n}\r\n\r\n/* ── Tab panel (mobile) ── */\r\n\r\n.govuk-tabs__panel {\r\n  /* govuk-responsive-margin(8, \"bottom\") — mobile: 30px */\r\n  margin-bottom: 30px;\r\n}\r\n\r\n@media (min-width: 40.0625em) {\r\n  .govuk-tabs__panel {\r\n    margin-bottom: 50px;\r\n  }\r\n}\r\n\r\n/* =============================================\r\n   JS-enabled tablet+ layout (horizontal tabs)\r\n   ============================================= */\r\n\r\n@media (min-width: 40.0625em) {\r\n  /* Hide mobile title */\r\n  .govuk-tabs--js-enabled .govuk-tabs__title {\r\n    display: none;\r\n  }\r\n\r\n  /* Tab bar with bottom border */\r\n  .govuk-tabs--js-enabled .govuk-tabs__list {\r\n    margin-bottom: 0;\r\n    border-bottom: 1px solid #cecece; /* govuk-functional-colour(border) */\r\n  }\r\n\r\n  /* Clearfix for floated items */\r\n  .govuk-tabs--js-enabled .govuk-tabs__list::after {\r\n    content: \"\";\r\n    display: block;\r\n    clear: both;\r\n  }\r\n\r\n  /* Horizontal tab items */\r\n  .govuk-tabs--js-enabled .govuk-tabs__list-item {\r\n    position: relative;\r\n    margin-right: 5px; /* govuk-spacing(1) */\r\n    margin-bottom: 0;\r\n    margin-left: 0;\r\n    padding: 10px 20px; /* govuk-spacing(2) govuk-spacing(4) */\r\n    float: left;\r\n    background-color: #f3f3f3; /* govuk-colour(\"black\", tint-95) */\r\n    text-align: center;\r\n  }\r\n\r\n  /* Remove mobile em-dash */\r\n  .govuk-tabs--js-enabled .govuk-tabs__list-item::before {\r\n    content: none;\r\n  }\r\n\r\n  /* Selected tab */\r\n  .govuk-tabs--js-enabled .govuk-tabs__list-item--selected {\r\n    position: relative;\r\n    margin-top: -5px; /* -govuk-spacing(1) */\r\n    /* Compensation for border: -1px */\r\n    margin-bottom: -1px;\r\n\r\n    /* Adjusted padding for border compensation */\r\n    padding-top: 14px;  /* govuk-spacing(3) - 1px = 15 - 1 */\r\n    padding-right: 19px; /* govuk-spacing(4) - 1px = 20 - 1 */\r\n    padding-bottom: 16px; /* govuk-spacing(3) + 1px = 15 + 1 */\r\n    padding-left: 19px;  /* govuk-spacing(4) - 1px = 20 - 1 */\r\n\r\n    border: 1px solid #cecece; /* govuk-functional-colour(border) */\r\n    border-bottom: 0;\r\n\r\n    background-color: #ffffff; /* govuk-functional-colour(body-background) */\r\n  }\r\n\r\n  /* Tab links in horizontal mode — govuk-link-style-text */\r\n  .govuk-tabs--js-enabled .govuk-tabs__tab {\r\n    margin-bottom: 0;\r\n    color: #0b0c0c;\r\n    text-decoration: underline;\r\n  }\r\n\r\n  .govuk-tabs--js-enabled .govuk-tabs__tab:link,\r\n  .govuk-tabs--js-enabled .govuk-tabs__tab:visited,\r\n  .govuk-tabs--js-enabled .govuk-tabs__tab:active {\r\n    color: #0b0c0c;\r\n  }\r\n\r\n  /* Expanded click target for tabs */\r\n  .govuk-tabs--js-enabled .govuk-tabs__tab::after {\r\n    content: \"\";\r\n    position: absolute;\r\n    top: 0;\r\n    right: 0;\r\n    bottom: 0;\r\n    left: 0;\r\n  }\r\n\r\n  /* Selected tab: remove underline */\r\n  .govuk-tabs--js-enabled .govuk-tabs__list-item--selected .govuk-tabs__tab {\r\n    text-decoration: none;\r\n  }\r\n\r\n  /* Tab panel (horizontal layout) */\r\n  .govuk-tabs--js-enabled .govuk-tabs__panel {\r\n    margin-bottom: 0;\r\n    padding: 30px 20px; /* govuk-spacing(6) govuk-spacing(4) */\r\n    border: 1px solid #cecece;\r\n    border-top: 0;\r\n  }\r\n\r\n  .govuk-tabs--js-enabled .govuk-tabs__p