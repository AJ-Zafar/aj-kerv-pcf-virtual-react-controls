 box-shadow: 0 2px 0 #0b0c0c;\r\n}\r\n\r\n.govuk-button::before {\r\n  content: \"\";\r\n  display: block;\r\n  position: absolute;\r\n  top: -2px;\r\n  right: -2px;\r\n  bottom: -4px;\r\n  left: -2px;\r\n  background: transparent;\r\n}\r\n\r\n.govuk-button:active::before {\r\n  top: -4px;\r\n}\r\n\r\n.govuk-button[disabled],\r\n.govuk-button[disabled]:hover {\r\n  opacity: 0.5;\r\n  background-color: #00703c;\r\n  cursor: not-allowed;\r\n}\r\n\r\n.govuk-button[disabled]:active {\r\n  top: 0;\r\n  box-shadow: 0 2px 0 #002d18;\r\n}\r\n\r\n/* Secondary button */\r\n.govuk-button--secondary {\r\n  background-color: #f3f2f1;\r\n  box-shadow: 0 2px 0 #929191;\r\n  color: #0b0c0c;\r\n}\r\n\r\n.govuk-button--secondary:link,\r\n.govuk-button--secondary:visited,\r\n.govuk-button--secondary:active,\r\n.govuk-button--secondary:hover {\r\n  color: #0b0c0c;\r\n}\r\n\r\n.govuk-button--secondary:hover {\r\n  background-color: #dbdad9;\r\n}\r\n\r\n.govuk-button--secondary[disabled],\r\n.govuk-button--secondary[disabled]:hover {\r\n  background-color: #f3f2f1;\r\n}\r\n\r\n/* Warning button */\r\n.govuk-button--warning {\r\n  background-color: #d4351c;\r\n  box-shadow: 0 2px 0 #55150b;\r\n  color: #fff;\r\n}\r\n\r\n.govuk-button--warning:link,\r\n.govuk-button--warning:visited,\r\n.govuk-button--warning:active,\r\n.govuk-button--warning:hover {\r\n  color: #fff;\r\n}\r\n\r\n.govuk-button--warning:hover {\r\n  background-color: #aa2a16;\r\n}\r\n\r\n.govuk-button--warning[disabled],\r\n.govuk-button--warning[disabled]:hover {\r\n  background-color: #d4351c;\r\n}\r\n\r\n/* Full width variant for explicit control */\r\n.govuk-button--full-width {\r\n  width: 100%;\r\n}\r\n"},"lineCount":null}},"error":null,"hash":"cb03017c0d19caaaf170449eac1257c5","cacheData":{"env":{}}}