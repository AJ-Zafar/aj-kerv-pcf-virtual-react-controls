.tsx":"import * as React from 'react';\r\nimport { classNames } from '../../utils/classNames';\r\nimport { ButtonProps } from './Button.types';\r\nimport './Button.css';\r\n\r\n/**\r\n * Button component for form actions\r\n * Follows GOV.UK Design System button pattern\r\n */\r\nexport const Button: React.FC<ButtonProps> = ({\r\n  children,\r\n  type = 'submit',\r\n  disabled,\r\n  fullWidth,\r\n  onClick,\r\n  className,\r\n  variant,\r\n}) => {\r\n  const classes = classNames(\r\n    'govuk-button',\r\n    variant === 'secondary' && 'govuk-button--secondary',\r\n    variant === 'warning' && 'govuk-button--warning',\r\n    fullWidth && 'govuk-button--full-width',\r\n    className\r\n  );\r\n\r\n  return (\r\n    <button\r\n      type={type}\r\n      disabled={disabled}\r\n      className={classes}\r\n      onClick={onClick}\r\n      aria-disabled={disabled ? 'true' : undefined}\r\n    >\r\n      {children}\r\n    </button>\r\n  );\r\n};\r\n"},"lineCount":null}},"error":null,"hash":"587297d666655dee136613c2bf7fb6a8","cacheData":{"env":{}}}