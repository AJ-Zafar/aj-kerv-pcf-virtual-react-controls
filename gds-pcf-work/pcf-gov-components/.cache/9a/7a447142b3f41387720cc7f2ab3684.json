"line":194,"column":0}}],"sources":{"../src/components/NotificationBanner/NotificationBanner.css":"/* NotificationBanner component styles - Based on GOV.UK Frontend v6.1.0 */\r\n\r\n/* ── Base banner ── */\r\n\r\n.govuk-notification-banner {\r\n  font-family: -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, Oxygen-Sans, Ubuntu, Cantarell, \"Helvetica Neue\", sans-serif;\r\n  -webkit-font-smoothing: antialiased;\r\n  -moz-osx-font-smoothing: grayscale;\r\n\r\n  /* govuk-font($size: 19) — mobile */\r\n  font-size: 1rem;\r\n  line-height: 1.25;\r\n  font-weight: 400;\r\n\r\n  /* govuk-responsive-margin(8, \"bottom\") — mobile: 30px */\r\n  margin-bottom: 30px;\r\n\r\n  /* $govuk-border-width solid brand (blue = #1d70b8) */\r\n  border: 5px solid #1d70b8;\r\n\r\n  background-color: #1d70b8;\r\n}\r\n\r\n/* govuk-font($size: 19) — tablet+ */\r\n@media (min-width: 40.0625em) {\r\n  .govuk-notification-banner {\r\n    font-size: 1.1875rem;\r\n    line-height: 1.31579;\r\n  }\r\n}\r\n\r\n/* govuk-responsive-margin(8, \"bottom\") — tablet+ */\r\n@media (min-width: 40.0625em) {\r\n  .govuk-notification-banner {\r\n    margin-bottom: 50px;\r\n  }\r\n}\r\n\r\n@media print {\r\n  .govuk-notification-banner {\r\n    font-family: sans-serif;\r\n    font-size: 14pt;\r\n    line-height: 1.15;\r\n  }\r\n}\r\n\r\n/* Focus state */\r\n.govuk-notification-banner:focus {\r\n  outline: 3px solid #ffdd00; /* govuk-functional-colour(focus) = yellow */\r\n}\r\n\r\n/* ── Header (coloured bar with title) ── */\r\n\r\n.govuk-notification-banner__header {\r\n  padding: 2px 15px 5px; /* 2px govuk-spacing(3) govuk-spacing(1) */\r\n\r\n  /* Ensures header appears separate to body in high contrast mode */\r\n  border-bottom: 1px solid transparent;\r\n}\r\n\r\n@media (min-width: 40.0625em) {\r\n  .govuk-notification-banner__header {\r\n    padding: 2px 20px 5px; /* 2px govuk-spacing(4) govuk-spacing(1) */\r\n  }\r\n}\r\n\r\n/* ── Title text ── */\r\n\r\n.govuk-notification-banner__title {\r\n  /* govuk-font-size($size: 19) — mobile */\r\n  font-size: 1rem;\r\n  line-height: 1.25;\r\n\r\n  font-weight: 700; /* govuk-typography-weight-bold */\r\n  margin: 0;\r\n  padding: 0;\r\n  color: #ffffff; /* govuk-colour(\"white\") */\r\n}\r\n\r\n@media (min-width: 40.0625em) {\r\n  .govuk-notification-banner__title {\r\n    font-size: 1.1875rem;\r\n    line-height: 1.31579;\r\n  }\r\n}\r\n\r\n/* ── Content area (white background) ── */\r\n\r\n.govuk-notification-banner__content {\r\n  padding: 15px; /* govuk-spacing(3) */\r\n  color: #0b0c0c; /* govuk-functional-colour(text) */\r\n  background-color: #ffffff; /* govuk-functional-colour(body-background) */\r\n}\r\n\r\n@media (min-width: 40.0625em) {\r\n  .govuk-notification-banner__content {\r\n    padding: 20px; /* govuk-spacing(4) */\r\n  }\r\n}\r\n\r\n/* Max-width to maintain readable line-lengths */\r\n.govuk-notification-banner__content > * {\r\n  box-sizing: border-box;\r\n  /* Roughly matches a two-thirds column width minus banner exterior */\r\n  max-width: 605px;\r\n}\r\n\r\n.govuk-notification-banner__content > :last-child {\r\n  margin-bottom: 0;\r\n}\r\n\r\n/* ── Content heading ── */\r\n\r\n.govuk-notification-banner__heading {\r\n  /* govuk-font-size($size: 24) — mobile */\r\n  font-size: 1.125rem;\r\n  line-height: 1.11111;\r\n\r\n  font-weight: 700; /* govuk-typography-weight-bold */\r\n  margin: 0 0 15px; /* govuk-spacing(3) */\r\n  padding: 0;\r\n}\r\n\r\n@media (min-width: 40.0625em) {\r\n  .govuk-notification-banner__heading {\r\n    font-size: 1.5rem;\r\n    line-height: 1.25;\r\n  }\r\n}\r\n\r\n/* ── Links inside banner ── */\r\n\r\n.govuk-notification-banner__link {\r\n  /* govuk-link-common */\r\n  text-decoration: underline;\r\n  text-decoration-thickness: max(1px, 0.0625rem);\r\n  text-underline-offset: 0.1578em;\r\n}\r\n\r\n.govuk-notification-banner__link:focus {\r\n  outline: 3px solid transparent;\r\n  color: #0b0c0c;\r\n  background-color: #ffdd00;\r\n  box-shadow: 0 -2px #ffdd00, 0 4px #0b0c0c;\r\n  text-decoration: none;\r\n}\r\n\r\n/* govuk-link-style-no-visited-state */\r\n.govuk-notification-banner__link:link {\r\n  color: #1a65a6; /* govuk-functional-colour(link) = blue shade-10 */\r\n}\r\n\r\n.govuk-notification-banner__link:visited {\r\n  color: #1a65a6; /* govuk-link-style-no-visited-state: same as link */\r\n}\r\n\r\n.govuk-notification-banner__link:hover {\r\n  color: #0f385c; /* govuk-functional-colour(link-hover) = blue shade-50 */\r\n  text-decoration-thickness: max(3px, 0.1875rem, 0.12em);\r\n  -webkit-text-decoration-skip-ink: none;\r\n  text-decoration-skip-ink: none;\r\n  -webkit-text-decoration-skip: none;\r\n  text-decoration-skip: none;\r\n}\r\n\r\n.govuk-notification-banner__link:active {\r\n  color: #0b0c0c; /* govuk-functional-colour(text) */\r\n}\r\n\r\n/* ── Success variant ── */\r\n\r\n.govuk-notification-banner--success {\r\n  border-color: #0f7a52; /* govuk-functional-colour(success) = green */\r\n  background-color: #0f7a52;\r\n}\r\n\r\n/* Success link colours — govuk-link-style-success */\r\n.govuk-notification-banner--success .govuk-notification-banner__link:link,\r\n.govuk-notification-banner--success .govuk-notification-banner__link:visited {\r\n  color: #0f7a52; /* govuk-functional-colour(success) */\r\n}\r\n\r\n.govuk-notification-banner--success .govuk-notification-banner__link:hover {\r\n  color: #083d29; /* govuk-colour(\"green\", \"shade-50\") */\r\n}\r\n\r\n.govuk-notification-banner--success .govuk-notification-banner__link:active {\r\n  color: #0f7a52;\r\n}\r\n\r\n.govuk-notification-banner--success .govuk-notification-banner__link:focus {\r\n  color: #0b0c0c; /* govuk-functional-colour(focus-text) */\r\n}\r\n"},"lineCount":194}},"error":null,"hash":"2bfc638fc886686696deb1d0ecfda0a9","cacheData":{"env":{}}}