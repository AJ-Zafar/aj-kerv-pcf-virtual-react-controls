case-col-description {\r\n  width: 47%;\r\n}\r\n\r\n.showcase-col-owner {\r\n  width: 20%;\r\n}\r\n\r\n.showcase-col-updated {\r\n  width: 15%;\r\n}\r\n\r\n.showcase-force-button-hover .govuk-button {\r\n  background-color: #005a30;\r\n}\r\n\r\n.showcase-force-button-focus .govuk-button {\r\n  border-color: #fd0;\r\n  color: #0b0c0c;\r\n  background-color: #fd0;\r\n  box-shadow: 0 2px 0 #0b0c0c;\r\n}\r\n\r\n.showcase-force-button-active .govuk-button {\r\n  top: 2px;\r\n}\r\n\r\n.showcase-force-input-focus .govuk-input,\r\n.showcase-force-input-focus .govuk-select,\r\n.showcase-force-input-focus .govuk-textarea {\r\n  outline: 3px solid #fd0;\r\n  outline-offset: 0;\r\n  box-shadow: inset 0 0 0 2px;\r\n}\r\n\r\n.showcase-force-checkbox-focus .govuk-checkboxes__item:first-child .govuk-checkboxes__label::before {\r\n  border-width: 4px;\r\n  outline: 3px solid transparent;\r\n  outline-offset: 1px;\r\n  box-shadow: 0 0 0 3px #fd0;\r\n}\r\n\r\n.showcase-force-radio-focus .govuk-radios__item:first-child .govuk-radios__label::before {\r\n  border-width: 4px;\r\n  outline: 3px solid transparent;\r\n  outline-offset: 1px;\r\n  box-shadow: 0 0 0 4px #fd0;\r\n}\r\n\r\n.showcase-force-link-focus .govuk-breadcrumbs__list-item:first-child .govuk-breadcrumbs__link {\r\n  outline: 3px solid #fd0;\r\n  outline-offset: 0;\r\n  background-color: #fd0;\r\n  color: #0b0c0c;\r\n  box-shadow: 0 -2px #fd0, 0 4px #0b0c0c;\r\n  text-decoration: none;\r\n}\r\n\r\n.showcase-force-pagination-focus .govuk-pagination__item:nth-child(2) .govuk-pagination__link {\r\n  outline: 3px solid transparent;\r\n  color: #0b0c0c;\r\n  background-color: #fd0;\r\n  box-shadow: 0 -2px #fd0, 0 4px #0b0c0c;\r\n  text-decoration: none;\r\n}"},"lineCount":null}},"error":null,"hash":"95aeb020b11f7fcbaed98e7dab9a622d","cacheData":{"env":{}}}