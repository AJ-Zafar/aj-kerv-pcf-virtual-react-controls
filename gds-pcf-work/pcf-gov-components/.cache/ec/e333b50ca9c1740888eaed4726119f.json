olumn":0},"generated":{"line":83,"column":0}},{"source":"../src/components/ErrorSummary/ErrorSummary.tsx","name":null,"original":{"line":70,"column":1},"generated":{"line":83,"column":1}},{"source":"../src/components/ErrorSummary/ErrorSummary.tsx","name":null,"original":{"line":11,"column":13},"generated":{"line":84,"column":0}},{"source":"../src/components/ErrorSummary/ErrorSummary.tsx","name":null,"original":{"line":11,"column":13},"generated":{"line":84,"column":7}},{"source":"../src/components/ErrorSummary/ErrorSummary.tsx","name":null,"original":{"line":11,"column":13},"generated":{"line":84,"column":8}},{"source":"../src/components/ErrorSummary/ErrorSummary.tsx","name":null,"original":{"line":11,"column":25},"generated":{"line":84,"column":20}},{"source":"../src/components/ErrorSummary/ErrorSummary.tsx","name":null,"original":{"line":11,"column":25},"generated":{"line":84,"column":23}},{"source":"../src/components/ErrorSummary/ErrorSummary.tsx","name":null,"original":{"line":11,"column":25},"generated":{"line":84,"column":35}}],"sources":{"../src/components/ErrorSummary/ErrorSummary.tsx":"import * as React from 'react';\r\nimport { classNames } from '../../utils/classNames';\r\nimport { ErrorSummaryProps } from './ErrorSummary.types';\r\nimport './ErrorSummary.css';\r\n\r\n/**\r\n * Error summary component displayed at the top of a page\r\n * to list all validation errors with links to the relevant fields.\r\n * Follows GOV.UK Design System error summary pattern.\r\n */\r\nexport const ErrorSummary: React.FC<ErrorSummaryProps> = ({\r\n  heading = 'There is a problem',\r\n  description,\r\n  errors,\r\n  onErrorClick,\r\n  className,\r\n}) => {\r\n  const handleClick = (\r\n    e: React.MouseEvent,\r\n    targetId: string\r\n  ): void => {\r\n    e.preventDefault();\r\n    if (onErrorClick) {\r\n      onErrorClick(targetId);\r\n    }\r\n  };\r\n\r\n  return (\r\n    <div\r\n      className={classNames('govuk-error-summary', className)}\r\n      role=\"alert\"\r\n      aria-labelledby=\"error-summary-title\"\r\n      tabIndex={-1}\r\n    >\r\n      <h2\r\n        className=\"govuk-error-summary__title\"\r\n        id=\"error-summary-title\"\r\n      >\r\n        {heading}\r\n      </h2>\r\n      <div className=\"govuk-error-summary__body\">\r\n        {description && <p>{description}</p>}\r\n        {errors.length > 0 && (\r\n          <ul className=\"govuk-error-summary__list\">\r\n            {errors.map(function (error) {\r\n              return (\r\n                <li key={error.targetId}>\r\n                  {onErrorClick ? (\r\n                    <button\r\n                      type=\"button\"\r\n                      onClick={function (e) {\r\n                        handleClick(e, error.targetId);\r\n                      }}\r\n                    >\r\n                      {error.text}\r\n                    </button>\r\n                  ) : (\r\n                    <a href={'#' + error.targetId}>\r\n                      {error.text}\r\n                    </a>\r\n                  )}\r\n                </li>\r\n              );\r\n            })}\r\n          </ul>\r\n        )}\r\n      </div>\r\n    </div>\r\n  );\r\n};\r\n"},"lineCount":null}},"error":null,"hash":"5e0b998c378daded330145233bc9066e","cacheData":{"env":{}}}