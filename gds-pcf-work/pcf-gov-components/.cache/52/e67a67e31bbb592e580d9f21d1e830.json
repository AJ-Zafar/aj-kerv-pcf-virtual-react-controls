"column":2},"generated":{"line":1,"column":2976}},{"source":"Breadcrumbs.css","name":null,"original":{"line":165,"column":0},"generated":{"line":1,"column":3001}}],"sources":{"Breadcrumbs.css":"/* Breadcrumbs component styles - Based on GOV.UK Frontend */\r\n/* Reference: govuk-frontend/src/govuk/components/breadcrumbs/_index.scss */\r\n\r\n.govuk-breadcrumbs {\r\n  font-family: -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, Oxygen-Sans, Ubuntu, Cantarell, \"Helvetica Neue\", sans-serif;\r\n  -webkit-font-smoothing: antialiased;\r\n  -moz-osx-font-smoothing: grayscale;\r\n  font-size: 0.875rem;\r\n  font-weight: 400;\r\n  line-height: 1.14286;\r\n  color: #0b0c0c;\r\n  margin-top: 15px;\r\n  margin-bottom: 10px;\r\n}\r\n\r\n@media (min-width: 40.0625em) {\r\n  .govuk-breadcrumbs {\r\n    font-size: 1rem;\r\n    line-height: 1.25;\r\n  }\r\n}\r\n\r\n@media print {\r\n  .govuk-breadcrumbs {\r\n    font-family: sans-serif;\r\n    font-size: 14pt;\r\n    line-height: 1.2;\r\n  }\r\n}\r\n\r\n.govuk-breadcrumbs__list {\r\n  margin: 0;\r\n  padding: 0;\r\n  list-style-type: none;\r\n  display: flex;\r\n  flex-wrap: wrap;\r\n}\r\n\r\n.govuk-breadcrumbs__list-item {\r\n  display: inline-block;\r\n  position: relative;\r\n  margin-bottom: 5px;\r\n  margin-left: 0.625em;\r\n  padding-left: calc(0.625em + 0.354em);\r\n}\r\n\r\n.govuk-breadcrumbs__list-item::before {\r\n  content: \"\";\r\n  display: block;\r\n  position: absolute;\r\n  top: 0;\r\n  bottom: 0;\r\n  left: calc(-0.354em * 2 + 0.4375em + 0.0625em);\r\n  width: 0.4375em;\r\n  height: 0.4375em;\r\n  margin: auto 0;\r\n  transform: rotate(45deg);\r\n  border: solid;\r\n  border-width: 1px 1px 0 0;\r\n  border-color: #505a5f;\r\n}\r\n\r\n.govuk-breadcrumbs__list-item:first-child {\r\n  margin-left: 0;\r\n  padding-left: 0;\r\n}\r\n\r\n.govuk-breadcrumbs__list-item:first-child::before {\r\n  content: none;\r\n  display: none;\r\n}\r\n\r\n/* Breadcrumb links use govuk-link-style-text: black text color in all states */\r\n.govuk-breadcrumbs__link,\r\n.govuk-breadcrumbs__button {\r\n  font: inherit;\r\n  color: #0b0c0c;\r\n  text-decoration: underline;\r\n  text-decoration-thickness: max(1px, .0625rem);\r\n  text-underline-offset: 0.1578em;\r\n}\r\n\r\n.govuk-breadcrumbs__button {\r\n  background: none;\r\n  border: 0;\r\n  padding: 0;\r\n  cursor: pointer;\r\n}\r\n\r\n.govuk-breadcrumbs__link:link,\r\n.govuk-breadcrumbs__link:visited,\r\n.govuk-breadcrumbs__link:active,\r\n.govuk-breadcrumbs__button:active {\r\n  color: #0b0c0c;\r\n}\r\n\r\n.govuk-breadcrumbs__link:hover,\r\n.govuk-breadcrumbs__button:hover {\r\n  color: #0b0c0c;\r\n  text-decoration-thickness: max(3px, .1875rem, .12em);\r\n  text-decoration-skip-ink: none;\r\n  text-decoration-skip: none;\r\n}\r\n\r\n.govuk-breadcrumbs__link:focus,\r\n.govuk-breadcrumbs__button:focus {\r\n  outline: 3px solid transparent;\r\n  outline-offset: 0;\r\n  color: #0b0c0c;\r\n  background-color: #fd0;\r\n  box-shadow: 0 -2px #fd0, 0 4px #0b0c0c;\r\n  text-decoration: none;\r\n}\r\n\r\n.govuk-breadcrumbs__current {\r\n  color: #0b0c0c;\r\n  text-decoration: none;\r\n}\r\n\r\n/* Collapse on mobile variant */\r\n@media (max-width: 40.0525em) {\r\n  .govuk-breadcrumbs--collapse-on-mobile .govuk-breadcrumbs__list-item {\r\n    display: none;\r\n  }\r\n\r\n  .govuk-breadcrumbs--collapse-on-mobile .govuk-breadcrumbs__list-item:first-child,\r\n  .govuk-breadcrumbs--collapse-on-mobile .govuk-breadcrumbs__list-item:last-child {\r\n    display: inline-block;\r\n  }\r\n\r\n  .govuk-breadcrumbs--collapse-on-mobile .govuk-breadcrumbs__list-item::before {\r\n    top: 0.375em;\r\n    margin: 0;\r\n  }\r\n\r\n  .govuk-breadcrumbs--collapse-on-mobile .govuk-breadcrumbs__list {\r\n    display: flex;\r\n  }\r\n}\r\n\r\n/* Inverse variant for dark backgrounds */\r\n.govuk-breadcrumbs--inverse {\r\n  color: #ffffff;\r\n}\r\n\r\n.govuk-breadcrumbs--inverse .govuk-breadcrumbs__link,\r\n.govuk-breadcrumbs--inverse .govuk-breadcrumbs__button {\r\n  color: #ffffff;\r\n}\r\n\r\n.govuk-breadcrumbs--inverse .govuk-breadcrumbs__link:link,\r\n.govuk-breadcrumbs--inverse .govuk-breadcrumbs__link:visited,\r\n.govuk-breadcrumbs--inverse .govuk-breadcrumbs__link:hover,\r\n.govuk-breadcrumbs--inverse .govuk-breadcrumbs__link:active {\r\n  color: #ffffff;\r\n}\r\n\r\n.govuk-breadcrumbs--inverse .govuk-breadcrumbs__link:focus,\r\n.govuk-breadcrumbs--inverse .govuk-breadcrumbs__button:focus {\r\n  color: #0b0c0c;\r\n}\r\n\r\n.govuk-breadcrumbs--inverse .govuk-breadcrumbs__list-item::before {\r\n  border-color: currentcolor;\r\n}\r\n"},"lineCount":null}},"error":null,"hash":"1e12dd2d311bd717e0a3a51c19f27050","cacheData":{"env":{}}}