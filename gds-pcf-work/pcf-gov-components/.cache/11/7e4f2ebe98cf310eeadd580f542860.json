}\r\n}\r\n\r\n@media print {\r\n  .govuk-task-list {\r\n    font-family: sans-serif;\r\n    font-size: 14pt;\r\n    line-height: 1.15;\r\n  }\r\n}\r\n\r\n/* ── List item (table row) ── */\r\n\r\n.govuk-task-list__item {\r\n  display: table;\r\n  position: relative;\r\n  width: 100%;\r\n  margin-bottom: 0;\r\n  padding-top: 10px;    /* govuk-spacing(2) */\r\n  padding-bottom: 10px; /* govuk-spacing(2) */\r\n  border-bottom: 1px solid #cecece; /* govuk-functional-colour(border) */\r\n}\r\n\r\n.govuk-task-list__item:first-child {\r\n  border-top: 1px solid #cecece;\r\n}\r\n\r\n/* Hover state for linked items */\r\n.govuk-task-list__item--with-link:hover {\r\n  background: #f3f3f3; /* govuk-colour(\"black\", tint-95) */\r\n}\r\n\r\n/* ── Name and hint (left cell) ── */\r\n\r\n.govuk-task-list__name-and-hint {\r\n  display: table-cell;\r\n  color: #0b0c0c; /* govuk-functional-colour(text) */\r\n  vertical-align: top;\r\n}\r\n\r\n/* ── Status (right cell) ── */\r\n\r\n.govuk-task-list__status {\r\n  display: table-cell;\r\n  padding-left: 10px; /* govuk-spacing(2) */\r\n  color: #0b0c0c; /* govuk-functional-colour(text) */\r\n  text-align: right;\r\n  vertical-align: top;\r\n}\r\n\r\n/* Plain text status (e.g. \"Cannot start yet\") */\r\n.govuk-task-list__status--cannot-start-yet {\r\n  color: #484949; /* govuk-functional-colour(secondary-text) = black tint-25 */\r\n}\r\n\r\n/* ── Task link — expanded click area covers entire row ── */\r\n\r\n.govuk-task-list__link {\r\n  /* govuk-link-common */\r\n  text-decoration: underline;\r\n  text-decoration-thickness: max(1px, 0.0625rem);\r\n  text-underline-offset: 0.1578em;\r\n  color: #1a65a6; /* govuk-functional-colour(link) */\r\n}\r\n\r\n.govuk-task-list__link:visited {\r\n  color: #54319f; /* govuk-colour(\"purple\") */\r\n}\r\n\r\n.govuk-task-list__link:hover {\r\n  color: #0f385c; /* govuk-functional-colour(link-hover) */\r\n  text-decoration-thickness: max(3px, 0.1875rem, 0.12em);\r\n  -webkit-text-decoration-skip-ink: none;\r\n  text-decoration-skip-ink: none;\r\n  -webkit-text-decoration-skip: none;\r\n  text-decoration-skip: none;\r\n}\r\n\r\n.govuk-task-list__link:active {\r\n  color: #0b0c0c; /* govuk-functional-colour(link-active) */\r\n}\r\n\r\n.govuk-task-list__link:focus {\r\n  outline: 3px solid transparent;\r\n  color: #0b0c0c;\r\n  background-color: #ffdd00;\r\n  box-shadow: 0 -2px #ffdd00, 0 4px #0b0c0c;\r\n  text-decoration: none;\r\n}\r\n\r\n/* Expanded click target — the entire row is clickable */\r\n.govuk-task-list__link::after {\r\n  content: \"\";\r\n  display: block;\r\n  position: absolute;\r\n  top: 0;\r\n  right: 0;\r\n  bottom: 0;\r\n  left: 0;\r\n}\r\n\r\n/* ── Hint text below task name ── */\r\n\r\n.govuk-task-list__hint {\r\n  margin-top: 5px; /* govuk-spacing(1) */\r\n  color: #484949; /* govuk-functional-colour(secondary-text) */\r\n}\r\n"},"lineCount":137}},"error":null,"hash":"f5c18c16ebda977b6f8484fc669b7f53","cacheData":{"env":{}}}