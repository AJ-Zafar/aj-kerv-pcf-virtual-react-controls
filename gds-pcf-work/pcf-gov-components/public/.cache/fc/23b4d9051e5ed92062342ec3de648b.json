 20px + 5px */\r\n  color: #1a65a6; /* govuk-functional-colour(link) = blue shade-10 */\r\n  cursor: pointer;\r\n}\r\n\r\n.govuk-details[open] .govuk-details__summary {\r\n  margin-bottom: 5px; /* govuk-spacing(1) */\r\n}\r\n\r\n/* Summary text underline */\r\n.govuk-details__summary-text {\r\n  text-decoration: underline;\r\n  text-decoration-thickness: max(1px, 0.0625rem);\r\n  text-underline-offset: 0.1578em;\r\n}\r\n\r\n.govuk-details__summary-text > :first-child {\r\n  margin-top: 0;\r\n}\r\n\r\n.govuk-details__summary-text > :only-child,\r\n.govuk-details__summary-text > :last-child {\r\n  margin-bottom: 0;\r\n}\r\n\r\n/* Summary hover */\r\n.govuk-details__summary:hover {\r\n  color: #0f385c; /* govuk-functional-colour(link-hover) = blue shade-50 */\r\n}\r\n\r\n.govuk-details__summary:hover .govuk-details__summary-text {\r\n  text-decoration-thickness: max(3px, 0.1875rem, 0.12em);\r\n  -webkit-text-decoration-skip-ink: none;\r\n  text-decoration-skip-ink: none;\r\n  -webkit-text-decoration-skip: none;\r\n  text-decoration-skip: none;\r\n}\r\n\r\n/* Summary focus */\r\n.govuk-details__summary:focus {\r\n  outline: 3px solid transparent;\r\n  color: #0b0c0c;\r\n  background-color: #fd0;\r\n  box-shadow: 0 -2px #fd0, 0 4px #0b0c0c;\r\n}\r\n\r\n.govuk-details__summary:focus .govuk-details__summary-text {\r\n  text-decoration: none;\r\n}\r\n\r\n/* Hide native marker */\r\n.govuk-details__summary::-webkit-details-marker {\r\n  display: none;\r\n}\r\n\r\n.govuk-details__summary::marker {\r\n  content: none;\r\n}\r\n\r\n/* Custom arrow - right (closed) */\r\n.govuk-details__summary::before {\r\n  content: \"\";\r\n  position: absolute;\r\n  top: -1px;\r\n  bottom: 0;\r\n  left: 0;\r\n  margin: auto 0;\r\n  display: block;\r\n  width: 0;\r\n  height: 0;\r\n  border-style: solid;\r\n  border-color: transparent;\r\n  clip-path: polygon(0% 0%, 100% 50%, 0% 100%);\r\n  border-width: 7px 0 7px 12.124px;\r\n  border-left-color: inherit;\r\n}\r\n\r\n/* Custom arrow - down (open) */\r\n.govuk-details[open] > .govuk-details__summary::before {\r\n  clip-path: polygon(0% 0%, 50% 100%, 100% 0%);\r\n  border-width: 12.124px 7px 0 7px;\r\n  border-left-color: transparent;\r\n  border-top-color: inherit;\r\n}\r\n\r\n/* Disclosed text */\r\n.govuk-details__text {\r\n  padding-top: 15px;  /* govuk-spacing(3) */\r\n  padding-bottom: 15px; /* govuk-spacing(3) */\r\n  padding-left: 20px; /* govuk-spacing(4) */\r\n  border-left: 5px solid #cecece; /* $govuk-border-width solid border */\r\n}\r\n\r\n.govuk-details__text p {\r\n  margin-top: 0;\r\n  margin-bottom: 20px; /* govuk-spacing(4) */\r\n}\r\n\r\n.govuk-details__text > :last-child {\r\n  margin-bottom: 0;\r\n}\r\n"},"lineCount":138}},"error":null,"hash":"c26e5cc4daa8f833cc466307897119ca","cacheData":{"env":{}}}