-border-width solid error */\r\n}\r\n\r\n@media (min-width: 40.0625em) {\r\n  .govuk-error-summary {\r\n    font-size: 1.1875rem;\r\n    line-height: 1.31579;\r\n    padding: 20px; /* govuk-responsive-padding(4) tablet */\r\n    margin-bottom: 50px; /* govuk-responsive-margin(8) tablet */\r\n  }\r\n}\r\n\r\n@media print {\r\n  .govuk-error-summary {\r\n    font-family: sans-serif;\r\n    font-size: 14pt;\r\n    line-height: 1.15;\r\n  }\r\n}\r\n\r\n.govuk-error-summary:focus {\r\n  outline: 3px solid #fd0; /* $govuk-focus-width solid focus */\r\n}\r\n\r\n/* Title */\r\n.govuk-error-summary__title {\r\n  font-size: 1.125rem; /* govuk-font-size(24) mobile = 18px ≈ 1.125rem */\r\n  line-height: 1.1111;\r\n  font-weight: 700;\r\n  margin-top: 0;\r\n  margin-bottom: 15px; /* govuk-responsive-margin(4) mobile = govuk-spacing(3) */\r\n}\r\n\r\n@media (min-width: 40.0625em) {\r\n  .govuk-error-summary__title {\r\n    font-size: 1.5rem; /* govuk-font-size(24) tablet = 24px */\r\n    line-height: 1.25;\r\n    margin-bottom: 20px; /* govuk-responsive-margin(4) tablet */\r\n  }\r\n}\r\n\r\n/* Body */\r\n.govuk-error-summary__body p {\r\n  margin-bottom: 0;\r\n}\r\n\r\n.govuk-error-summary__body > * + * {\r\n  margin-top: 15px; /* govuk-responsive-margin(4) mobile */\r\n}\r\n\r\n@media (min-width: 40.0625em) {\r\n  .govuk-error-summary__body > * + * {\r\n    margin-top: 20px;\r\n  }\r\n}\r\n\r\n.govuk-error-summary__body > :last-child {\r\n  margin-bottom: 5px; /* govuk-responsive-margin(1) */\r\n}\r\n\r\n/* Error list */\r\n.govuk-error-summary__list {\r\n  margin: 0;\r\n  padding: 0;\r\n  list-style: none;\r\n}\r\n\r\n.govuk-error-summary__list li {\r\n  margin-bottom: 5px; /* govuk-spacing(1) */\r\n}\r\n\r\n.govuk-error-summary__list li:last-child {\r\n  margin-bottom: 0;\r\n}\r\n\r\n/* Error links - govuk-link-common + govuk-link-style-error */\r\n.govuk-error-summary__list a {\r\n  font-weight: 700;\r\n  color: #ca3535; /* error colour */\r\n  text-decoration: underline;\r\n  text-decoration-thickness: max(1px, .0625rem);\r\n  text-underline-offset: 0.1578em;\r\n}\r\n\r\n.govuk-error-summary__list a:link,\r\n.govuk-error-summary__list a:visited {\r\n  color: #ca3535;\r\n}\r\n\r\n.govuk-error-summary__list a:hover {\r\n  color: #651b1b; /* red shade-50 */\r\n  text-decoration-thickness: max(3px, 0.1875rem, 0.12em);\r\n  -webkit-text-decoration-skip-ink: none;\r\n  text-decoration-skip-ink: none;\r\n  -webkit-text-decoration-skip: none;\r\n  text-decoration-skip: none;\r\n}\r\n\r\n.govuk-error-summary__list a:active {\r\n  color: #ca3535;\r\n}\r\n\r\n.govuk-error-summary__list a:focus {\r\n  outline: 3px solid transparent;\r\n  color: #0b0c0c; /* focus-text */\r\n  background-color: #fd0;\r\n  box-shadow: 0 -2px #fd0, 0 4px #0b0c0c;\r\n  text-decoration: none;\r\n}\r\n\r\n/* Button-style links (when no href, acting as buttons) */\r\n.govuk-error-summary__list button {\r\n  font-family: inherit;\r\n  font-size: inherit;\r\n  font-weight: 700;\r\n  color: #ca3535;\r\n  background: none;\r\n  border: none;\r\n  padding: 0;\r\n  margin: 0;\r\n  cursor: pointer;\r\n  text-decoration: underline;\r\n  text-decoration-thickness: max(1px, .0625rem);\r\n  text-underline-offset: 0.1578em;\r\n  text-align: left;\r\n}\r\n\r\n.govuk-error-summary__list button:hover {\r\n  color: #651b1b;\r\n  text-decoration-thickness: max(3px, 0.1875rem, 0.12em);\r\n}\r\n\r\n.govuk-error-summary__list button:focus {\r\n  outline: 3px solid transparent;\r\n  color: #0b0c0c;\r\n  background-color: #fd0;\r\n  box-shadow: 0 -2px #fd0, 0 4px #0b0c0c;\r\n  text-decoration: none;\r\n}\r\n\r\n.govuk-error-summary__list button:active {\r\n  color: #ca3535;\r\n}\r\n"},"lineCount":156}},"error":null,"hash":"1004b8b3aedcefd4effa4aa3fdaefed7","cacheData":{"env":{}}}