em) => (\r\n          <li\r\n            key={`${item.text}-${item.href || 'nolink'}-${item.isCurrent ? 'current' : 'item'}`}\r\n            className=\"govuk-breadcrumbs__list-item\"\r\n          >\r\n            {renderItemContent(item)}\r\n          </li>\r\n        ))}\r\n      </ol>\r\n    </nav>\r\n  );\r\n};\r\n"},"lineCount":null}},"error":null,"hash":"8b6a38bbc6347674f9eb03f929dc052d","cacheData":{"env":{}}}